# URL base de la API del backend
# En desarrollo local: http://localhost:5000/api
# En red LAN (start-mobile.bat): el script la detecta automáticamente
VITE_API_URL=http://localhost:5000/api

# Puerto del servidor Vite (cliente)
# Por defecto Vite usa 5173 si no se define esta variable.
# Si cambias este valor, start-mobile.bat lo detectará automáticamente.
# VITE_PORT=5173

# Credenciales Azure AD (autenticación)
VITE_AZURE_AD_CLIENT_ID=3672e35e-4d84-41b1-885a-a335948c4750
VITE_AZURE_AD_TENANT_ID=fd8a7e94-3179-471f-b79c-a64f8bfc8536

# Credenciales Google OAuth
VITE_GOOGLE_CLIENT_ID=TU_CLIENT_ID_DE_GOOGLE.apps.googleusercontent.com

# Intervalo de sincronización automática en segundos para portería
# Valor por defecto: 60
VITE_SYNC_INTERVAL_SECONDS=60

# Intervalo de chequeo de nueva versión en segundos (3600 = 1 hora)
VITE_VERSION_CHECK_INTERVAL=3600

# VITE_ENABLE_VERSION_CHECK: Habilita el chequeo de nuevas versiones contra el servidor.
# Valores: false (deshabilitado - default para evitar bucles en dev), true
VITE_ENABLE_VERSION_CHECK=false

# Reglamento Normativo/Novedades
VITE_REGLAMENTO_SHEET_URL=https://docs.google.com/spreadsheets/d/13Wx20TaRO4fwjXiXOlY1UB2aw0QfW_GoGZhz-gVQTDU/export?format=csv

# Feature Flags (habilitar/deshabilitar funciones)
# VITE_ENABLE_GOOGLE_LOGIN: Permite el inicio de sesión con cuentas de Google.
# Valores: true (habilitado - default), false (deshabilitado)
VITE_ENABLE_GOOGLE_LOGIN=true

# VITE_ENABLE_DOCUMENTS: Permite adjuntar remitos, facturas y otros documentos.
# Valores: true (habilitado - default), false (deshabilitado)
VITE_ENABLE_DOCUMENTS=true

# VITE_ENABLE_QR: Permite la generación y escaneo de códigos QR para autorizaciones.
# Valores: true (habilitado - default), false (deshabilitado)
VITE_ENABLE_QR=true

# VITE_MOCK_AUTH: Bypass de autenticación para desarrollo local (Mock Login).
# USO: Si es true y se corre en modo DEV, entra como el usuario especificado en VITE_MOCK_AUTH_EMAIL.
# IMPORTANTE: No debe estar activo en producción.
# Valores: false (default), true
VITE_MOCK_AUTH=false

# VITE_MOCK_AUTH_EMAIL: Email del usuario para el Mock Login (ej: gabrielt@donyeyo.com.ar).
# Requerido si VITE_MOCK_AUTH=true.
# VITE_MOCK_AUTH_EMAIL=
